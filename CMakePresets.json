{
	"version": 3,
	"configurePresets": [
		{
			"name": "default",
			"description": "Generate Ninja project files",
			"binaryDir": "${sourceDir}/build"
		},
		{
			"name": "vcpkg",
			"inherits": [
				"default"
			],
			"description": "Configure with vcpkg toolchain and generate Ninja project files",
			"toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
		},
		{
			"name": "asan-linux",
			"inherits": [
				"default"
			],
			"description": "Configure AddressSanitizer with system packages for Linux/WSL",
			"binaryDir": "${sourceDir}/build-asan-linux",
			"cacheVariables": {
				"BUILD_TESTING": "OFF",
				"CMAKE_BUILD_TYPE": "Debug",
				"ENABLE_ASAN": "ON",
				"USE_MIMALLOC": "OFF"
			}
		},
		{
			"name": "valgrind-linux",
			"inherits": [
				"default"
			],
			"description": "Configure a Valgrind-friendly Linux/WSL build without mimalloc",
			"binaryDir": "${sourceDir}/build-valgrind-linux",
			"cacheVariables": {
				"BUILD_TESTING": "OFF",
				"CMAKE_BUILD_TYPE": "RelWithDebInfo",
				"USE_MIMALLOC": "OFF"
			}
		},
		{
			"name": "release-portable-linux",
			"inherits": [
				"default"
			],
			"description": "Configure a portable Linux Release build without -march=native",
			"binaryDir": "${sourceDir}/build-release-portable-linux",
			"cacheVariables": {
				"BUILD_TESTING": "OFF",
				"CMAKE_BUILD_TYPE": "Release",
				"ENABLE_NATIVE_OPTIMIZATIONS": "OFF",
				"USE_MIMALLOC": "ON"
			}
		},
		{
			"name": "asan-vcpkg",
			"inherits": [
				"vcpkg"
			],
			"description": "Configure with vcpkg and AddressSanitizer enabled",
			"binaryDir": "${sourceDir}/build-asan",
			"cacheVariables": {
				"BUILD_TESTING": "ON",
				"CMAKE_BUILD_TYPE": "Debug",
				"ENABLE_ASAN": "ON"
			}
		}
	],
	"buildPresets": [
		{
			"name": "default",
			"configurePreset": "default"
		},
		{
			"name": "vcpkg",
			"configurePreset": "vcpkg"
		},
		{
			"name": "asan-linux",
			"configurePreset": "asan-linux",
			"configuration": "Debug"
		},
		{
			"name": "valgrind-linux",
			"configurePreset": "valgrind-linux",
			"configuration": "RelWithDebInfo"
		},
		{
			"name": "release-portable-linux",
			"configurePreset": "release-portable-linux",
			"configuration": "Release"
		},
		{
			"name": "asan-vcpkg",
			"configurePreset": "asan-vcpkg",
			"configuration": "Debug"
		}
	],
	"testPresets": [
		{
			"name": "default",
			"configurePreset": "default"
		},
		{
			"name": "vcpkg",
			"configurePreset": "vcpkg"
		},
		{
			"name": "asan-linux",
			"configurePreset": "asan-linux",
			"configuration": "Debug"
		},
		{
			"name": "valgrind-linux",
			"configurePreset": "valgrind-linux",
			"configuration": "RelWithDebInfo"
		},
		{
			"name": "release-portable-linux",
			"configurePreset": "release-portable-linux",
			"configuration": "Release"
		},
		{
			"name": "asan-vcpkg",
			"configurePreset": "asan-vcpkg",
			"configuration": "Debug"
		}
	]
}
